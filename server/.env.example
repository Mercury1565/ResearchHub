# ── Server ────────────────────────────────────────────────────────────────────
PORT=8080
ALLOWED_ORIGINS=http://localhost:5173

# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgres://postgres:postgres@localhost:5432/researchhub?sslmode=disable

# ── Object Storage (S3-compatible) ────────────────────────────────────────────
# Local dev: point at MinIO. Production: swap endpoint + credentials for real S3
# or any S3-compatible store (Cloudflare R2, Backblaze B2, etc.)
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY_ID=minioadmin
S3_SECRET_ACCESS_KEY=minioadmin
S3_BUCKET=researchhub
S3_REGION=us-east-1
S3_USE_SSL=false           # set to true for AWS S3 / production

# ── LLM Provider ──────────────────────────────────────────────────────────────
# Which provider to use for embeddings and chat.
# Accepted values: gemini | anthropic | openai
LLM_PROVIDER=gemini

# ── API Keys ──────────────────────────────────────────────────────────────────
# Only the key matching LLM_PROVIDER is required at runtime.
# Leave the others blank until you enable those providers.
GEMINI_API_KEY=AIza...
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...
